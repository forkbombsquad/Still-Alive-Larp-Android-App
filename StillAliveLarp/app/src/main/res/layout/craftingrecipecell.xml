<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/customborder_gray"
    android:padding="8dp">

    <!-- Name and Category in one row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/craftingrecipecell_name"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:text="Recipe Name"/>

        <TextView
            android:id="@+id/craftingrecipecell_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/green"
            android:textSize="12sp"
            android:text="[Category]"/>

    </LinearLayout>

    <!-- Makes -->
    <TextView
        android:id="@+id/craftingrecipecell_produces"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:text="Makes x1"/>

    <!-- Materials -->
    <TextView
        android:id="@+id/craftingrecipecell_materials"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:paddingTop="4dp"
        android:text="2 Metal, 2 Wood"/>

    <!-- Time -->
    <TextView
        android:id="@+id/craftingrecipecell_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="14sp"
        android:paddingTop="4dp"
        android:text="Time: 5 min"/>

    <!-- Skill -->
    <TextView
        android:id="@+id/craftingrecipecell_skill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/blue"
        android:textSize="14sp"
        android:text="Requires: Firearms"/>

    <!-- Description -->
    <TextView
        android:id="@+id/craftingrecipecell_desc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:textSize="12sp"
        android:paddingTop="4dp"
        android:textStyle="italic"
        android:text="Optional notes here"/>

</LinearLayout>