<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/light_gray"
    tools:context=".views.community.ViewCampStatusActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp">

            <TextView
                android:id="@+id/campstatus_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Camp Status"
                android:textStyle="bold"
                android:textSize="32sp"
                android:textAlignment="center"/>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginRight="8dp"
                android:layout_marginTop="16dp"/>

            <com.forkbombsquad.stillalivelarp.utils.KeyValueView
                android:id="@+id/campstatus_npcSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:key="NPC Slots"
                app:showDiv="false"/>

            <com.forkbombsquad.stillalivelarp.utils.KeyValueView
                android:id="@+id/campstatus_medicalCots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:key="Medical Cots"
                app:showDiv="false"/>

            <com.forkbombsquad.stillalivelarp.utils.KeyValueView
                android:id="@+id/campstatus_teachingChairs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:key="Teaching Chairs"
                app:showDiv="true"/>

            <TextView
                android:id="@+id/campstatus_forttitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="24dp"
                android:text="Fortifications"
                android:textStyle="bold"
                android:textSize="24sp"
                android:textColor="@color/black"
                android:textAlignment="textStart"/>

            <com.forkbombsquad.stillalivelarp.utils.LoadingLayout
                android:id="@+id/loadinglayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/campstatus_fortlayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout> <!-- BEFORE THIS ONE-->

    </ScrollView>

</LinearLayout>